# Server
PORT=4001

# Azure SQL Database
# Server format: <server-name>.database.windows.net
DB_HOST=your-server-name.database.windows.net
DB_PORT=1433
DB_NAME=eventsdb
DB_USER=your_admin_user
DB_PASSWORD=your_password
DB_ENCRYPT=true
# Set to true only for a local SQL Server container with a self-signed cert.
DB_TRUST_SERVER_CERT=false

# Low seat availability alert (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
ALERT_EMAIL_FROM=alerts@yourdomain.com
ALERT_EMAIL_TO=organizer@yourdomain.com
# Alert fires once when seats_available drops below this number.
LOW_SEATS_THRESHOLD=10
