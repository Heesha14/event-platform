# Copy this file to aks.env and fill in your values.
# aks.env is sourced by deploy-aks.sh and used to render the *.yaml.tpl
# files with envsubst. It contains your Azure SQL Database admin password,
# so keep aks.env out of version control (it's already git-ignored below).

# --- Resource group / cluster --------------------------------------------
RESOURCE_GROUP=event-platform
LOCATION=indiasouthcentral
AKS_CLUSTER_NAME=event-platform-aks
ACR_NAME=eventplatformacr          # must be globally unique, alphanumeric only

# --- Container image tag ---------------------------------------------------
IMAGE_TAG=v1

# --- Azure SQL Database -----------------------------------------------------
SQL_SERVER_NAME=event-platform-service      # without the .database.windows.net suffix
SQL_HOST=event-platform-service.database.windows.net
SQL_ADMIN_USER=dbadmin
SQL_ADMIN_PASSWORD=Thamanna@12        # never commit the real value

# --- ClickHouse (runs in-cluster, not an Azure-managed service) ------------
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=Thamanna@12       # never commit the real value
