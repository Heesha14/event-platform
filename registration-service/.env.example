# Server
PORT=4003

# Azure Database for PostgreSQL - Flexible Server (Free Tier)
PGHOST=your-server-name.postgres.database.azure.com
PGPORT=5432
PGDATABASE=registrationsdb
PGUSER=your_admin_user
PGPASSWORD=your_password
PGSSLMODE=require

# URL of the Event Service, used to check/reserve seats when a registration is made
EVENT_SERVICE_URL=http://localhost:4001
